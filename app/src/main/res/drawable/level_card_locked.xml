<?xml version="1.0" encoding="utf-8"?>
<!--
    level_card_locked.xml
    Place in: app/src/main/res/drawable/level_card_locked.xml
    Background for a locked level card — same shape but muted/dim colors
    to visually communicate unavailability.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Darker, more muted fill -->
    <solid android:color="#0D0D18" />

    <!-- Dim grey border instead of neon -->
    <stroke
        android:width="2dp"
        android:color="#33FFFFFF" />

    <!-- Same corner radius as unlocked card -->
    <corners android:radius="12dp" />
</shape>