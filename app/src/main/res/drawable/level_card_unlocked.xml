<?xml version="1.0" encoding="utf-8"?>
<!--
    level_card_unlocked.xml
    Place in: app/src/main/res/drawable/level_card_unlocked.xml
    Background for a playable level card — dark navy with cyan border.
    Matches the game's neon glass-morphism HUD style.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Dark navy fill matching game background -->
    <solid android:color="#1A1A2E" />

    <!-- Neon cyan border (matches HUD line color #00D4FF) -->
    <stroke
        android:width="2dp"
        android:color="#FF00D4FF" />

    <!-- Rounded corners -->
    <corners android:radius="12dp" />

    <!-- Inner padding (handled by layout, not needed here) -->
</shape>